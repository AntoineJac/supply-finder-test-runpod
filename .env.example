# ── LLM model ─────────────────────────────────────────────────────────────────
# HuggingFace model path loaded by vLLM
# FP8 quantised variant (24 GB GPU): unsloth/GLM-4.7-Flash-FP8-Dynamic
# Full precision (40 GB+ GPU):       zai-org/GLM-4.7-Flash
MODEL_NAME=zai-org/GLM-4.7-Flash
# Name exposed on the OpenAI-compatible /v1/* endpoints
SERVED_MODEL_NAME=glm-4.7-flash

# ── Embedding & reranker models ───────────────────────────────────────────────
EMBED_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L4-v2

# ── vLLM engine tuning ────────────────────────────────────────────────────────
# Number of GPUs for tensor parallelism (1 for single GPU)
TENSOR_PARALLEL_SIZE=1
# Fraction of GPU memory reserved for the LLM KV-cache
# Lower this (e.g. 0.80) to leave room for embed + rerank models on the same GPU
GPU_MEMORY_UTILIZATION=0.80
# Maximum context length in tokens
MAX_MODEL_LEN=16384
# FastAPI port (RunPod LB reads from $PORT automatically)
PORT=80
